generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}
model Schools { 

  id       Int       @id @default(autoincrement()) 

  name     String    @unique 

  email    String    @unique 

  phone    Int 

  motto    String 

  vision   String 

  teachers Teachers[] 

  students Students[] 

} 

  

model Teachers { 

  id       Int      @id @default(autoincrement()) 

  name     String 

  gender   String 

  email    String 

  phone    Int 

  schoolId Int 

  school   Schools  @relation(fields: [schoolId], references: [id], onDelete: Cascade) 

  createdAt DateTime @default(now()) 

} 

  

model Students { 

  id        Int      @id @default(autoincrement()) 

  name      String 

  gender    String 

  dob       DateTime 

  schoolId  Int 

  school    Schools  @relation(fields: [schoolId], references: [id], onDelete: Cascade) 

  grade     String   // current grade 

  createdAt DateTime @default(now()) 

  

  results   Results[] 

} 

  

model Subjects { 

  id      Int      @id @default(autoincrement()) 

  name    String   @unique 

  createdAt DateTime @default(now()) 

  results Results[] 

} 

  

model Exams { 

  id       Int       @id @default(autoincrement()) 

  exam     String    @unique 

  term     String 

  year     DateTime  @default(now()) 

  results  Results[] 

} 

  

model Results { 

  id        Int      @id @default(autoincrement()) 

  studentId Int 

  subjectId Int 

  examId    Int 

  score     Int 

  

  student   Students @relation(fields: [studentId], references: [id], onDelete: Cascade) 

  subject   Subjects @relation(fields: [subjectId], references: [id], onDelete: Cascade) 

  exam      Exams    @relation(fields: [examId], references: [id], onDelete: Cascade) 

} 

 